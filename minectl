#!/bin/bash

# minectl — remote Minecraft server automation CLI
# Requires centralized config at /home/minecraft-servers/ or custom path

set -euo pipefail

MINECTL_VERSION="0.3.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$SCRIPT_DIR/lib"

source "$LIB_DIR/config.sh"

usage() {
    cat <<'EOF'
minectl v0.3.0 — remote Minecraft server automation

Usage:
  minectl init <user@host> [--config-dir PATH]
  minectl create-server <user@host> --server-name NAME [--port PORT] [--memory MEMORY] [--jar JAR_URL]
  minectl start <user@host> --server-name NAME
  minectl stop <user@host> --server-name NAME
  minectl status <user@host> --server-name NAME
  minectl logs <user@host> --server-name NAME [--follow]
  minectl list <user@host>
  minectl config <user@host> [--server-name NAME] [--key KEY] [--value VALUE]
  minectl validate <user@host> [--server-name NAME]
  minectl version

Commands:
  init              Initialize centralized config on remote host (interactive)
  create-server     Create and deploy a new Minecraft server
  start             Start a Minecraft server (via systemd)
  stop              Stop a Minecraft server (via systemd)
  status            Check server status
  logs              View server logs
  list              List all configured servers
  config            View or modify configuration
  validate          Validate config completeness
  version           Show version

Options:
  --server-name NAME       Name of the server
  --port PORT              Minecraft server port
  --memory MEMORY          JVM memory allocation
  --jar JAR_URL            Direct URL to server JAR
  --config-dir PATH        Config directory path (default: /home/minecraft-servers)
  --follow                 Follow logs in real-time
  --key KEY                Config key to view/set
  --value VALUE            Config value to set

Config Structure:
  /home/minecraft-servers/
  ├── config                    # Global config (JAVA_VERSION, MC_USER, MC_BASE_DIR)
  └── servers/
      ├── survival.conf         # Per-server config (ENABLED, PORT, MEMORY, JAR_URL)
      ├── creative.conf
      └── ...

Priority:
  Server-side config has full authority. Client-side is read-only reference.

EOF
    exit 1
}

version() {
    echo "minectl v${MINECTL_VERSION}"
}

# Initialize config on remote host (interactive)
init() {
    local remote_user_host="$1"
    local config_dir="${CONFIG_DIR:-/home/minecraft-servers}"

    echo "$(color_blue "Initializing minectl on $remote_user_host...")"
    echo "Config directory: $config_dir"
    echo ""

    # Create remote config directory
    ssh "$remote_user_host" "mkdir -p '$config_dir/servers' && chmod 755 '$config_dir'"

    # Create global config interactively
    echo "$(color_yellow "Setting up global configuration...")"
    
    local java_version=$(prompt_config_value "Java version" "17")
    local mc_user=$(prompt_config_value "Minecraft user" "minecraft")
    local mc_base_dir=$(prompt_config_value "Minecraft base directory" "/opt/minecraft")

    # Create global config
    ssh "$remote_user_host" "cat > '$config_dir/config' <<EOFCONF
# minectl global configuration
# Generated: $(date)

JAVA_VERSION=$java_version
MC_USER=$mc_user
MC_BASE_DIR=$mc_base_dir

EOFCONF
"

    echo "$(color_green "✓ Global config created.")"
    echo ""
    echo "$(color_blue "Next steps:")"
    echo "  minectl create-server $remote_user_host --server-name survival"
    echo "  minectl create-server $remote_user_host --server-name creative"
    echo "  minectl list $remote_user_host"
}

# Create a new server
create_server() {
    local remote_user_host="$1"
    local server_name="$2"
    local port="${PORT:-25565}"
    local memory="${MEMORY:-2G}"
    local jar_url="${JAR_URL:-}"
    local config_dir=$(get_config_dir "$remote_user_host")

    [[ -z "$server_name" ]] && { echo "$(color_red "✗ --server-name required")"; exit 1; }

    echo "$(color_blue "Creating server: $server_name")"

    # Validate global config exists
    declare -A global_config
    if ! load_global_config "$config_dir" global_config 2>/dev/null; then
        echo "$(color_red "✗ Global config not found. Run: minectl init $remote_user_host")"
        exit 1
    fi

    # Create server config
    local java_version=$(get_config_value global_config "JAVA_VERSION")
    local mc_user=$(get_config_value global_config "MC_USER")
    local mc_base_dir=$(get_config_value global_config "MC_BASE_DIR")

    local server_config="$config_dir/servers/$server_name.conf"

    # Download JAR URL if not provided
    if [[ -z "$jar_url" ]]; then
        echo "Detecting latest Minecraft JAR..."
        jar_url="https://launcher.mojang.com/v1/objects/8dd1a28015f51b1803213892b50b7b4116555cfa/server.jar"
    fi

    # Create server config on remote
    ssh "$remote_user_host" "cat > '$server_config' <<EOFCONF
# minectl server configuration: $server_name
# Generated: $(date)

ENABLED=true
PORT=$port
MEMORY=$memory
JAR_URL=$jar_url

EOFCONF
"

    echo "$(color_green "✓ Server config created: $server_config")"

    # Deploy server (bootstrap)
    echo "Deploying server..."
    scp -q "$SCRIPT_DIR/bootstrap/bootstrap.sh" "$remote_user_host:/tmp/minectl-bootstrap.sh"
    
    ssh "$remote_user_host" "bash /tmp/minectl-bootstrap.sh \
        --server-name '$server_name' \
        --port '$port' \
        --memory '$memory' \
        --jar '$jar_url' \
        --java-version '$java_version' \
        --mc-user '$mc_user' \
        --mc-base-dir '$mc_base_dir'"

    echo "$(color_green "✓ Server deployed.")"
    echo ""
    echo "$(color_blue "Next:")"
    echo "  minectl start $remote_user_host --server-name $server_name"
}

start() {
    local remote_user_host="$1"
    local server_name="$2"

    [[ -z "$server_name" ]] && { echo "$(color_red "✗ --server-name required")"; exit 1; }

    local service_name="minecraft-${server_name}"
    echo "$(color_blue "Starting $server_name...")"
    
    ssh "$remote_user_host" "sudo systemctl start '$service_name'"
    echo "$(color_green "✓ Started.")"
}

stop() {
    local remote_user_host="$1"
    local server_name="$2"

    [[ -z "$server_name" ]] && { echo "$(color_red "✗ --server-name required")"; exit 1; }

    local service_name="minecraft-${server_name}"
    echo "$(color_blue "Stopping $server_name...")"
    
    ssh "$remote_user_host" "sudo systemctl stop '$service_name'"
    echo "$(color_green "✓ Stopped.")"
}

status() {
    local remote_user_host="$1"
    local server_name="$2"

    [[ -z "$server_name" ]] && { echo "$(color_red "✗ --server-name required")"; exit 1; }

    local service_name="minecraft-${server_name}"
    ssh "$remote_user_host" "sudo systemctl status '$service_name'"
}

logs() {
    local remote_user_host="$1"
    local server_name="$2"
    local follow_flag=""

    [[ -z "$server_name" ]] && { echo "$(color_red "✗ --server-name required")"; exit 1; }

    [[ "${FOLLOW:-0}" == "1" ]] && follow_flag="-f"

    local service_name="minecraft-${server_name}"
    ssh "$remote_user_host" "sudo journalctl -u '$service_name' -n 50 $follow_flag"
}

list_servers() {
    local remote_user_host="$1"
    local config_dir=$(get_config_dir "$remote_user_host")

    echo "$(color_blue "Servers on $remote_user_host:")"
    ssh "$remote_user_host" "
        servers_dir='$config_dir/servers'
        if [[ -d \$servers_dir ]]; then
            for conf in \$servers_dir/*.conf; do
                [[ -f \$conf ]] || continue
                server_name=\$(basename \$conf .conf)
                enabled=\$(grep '^ENABLED=' \$conf | cut -d= -f2 || echo 'unknown')
                port=\$(grep '^PORT=' \$conf | cut -d= -f2 || echo 'unknown')
                
                if [[ \$enabled == 'true' ]]; then
                    echo \"  ✓ \$server_name (port \$port)\"
                else
                    echo \"  ✗ \$server_name (port \$port, disabled)\"
                fi
            done
        fi
    "
}

validate_config() {
    local remote_user_host="$1"
    local server_name="${2:-}"
    local config_dir=$(get_config_dir "$remote_user_host")

    if [[ -n "$server_name" ]]; then
        echo "$(color_blue "Validating $server_name config...")"
        declare -A server_config
        if load_server_config "$config_dir" "$server_name" server_config; then
            echo "$(color_green "✓ Server config valid.")"
        else
            exit 1
        fi
    else
        echo "$(color_blue "Validating global config...")"
        declare -A global_config
        if load_global_config "$config_dir" global_config; then
            echo "$(color_green "✓ Global config valid.")"
        else
            exit 1
        fi
    fi
}

# Parse arguments
[[ $# -eq 0 ]] && usage

COMMAND="$1"
shift

case "$COMMAND" in
    init)
        [[ $# -lt 1 ]] && usage
        REMOTE="$1"
        shift
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --config-dir) CONFIG_DIR="$2"; shift 2 ;;
                *) echo "Unknown option: $1"; usage ;;
            esac
        done
        init "$REMOTE"
        ;;
    create-server)
        [[ $# -lt 1 ]] && usage
        REMOTE="$1"
        shift
        SERVER_NAME=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --server-name) SERVER_NAME="$2"; shift 2 ;;
                --port) PORT="$2"; shift 2 ;;
                --memory) MEMORY="$2"; shift 2 ;;
                --jar) JAR_URL="$2"; shift 2 ;;
                *) echo "Unknown option: $1"; usage ;;
            esac
        done
        create_server "$REMOTE" "$SERVER_NAME"
        ;;
    start)
        [[ $# -lt 1 ]] && usage
        REMOTE="$1"
        shift
        SERVER_NAME=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --server-name) SERVER_NAME="$2"; shift 2 ;;
                *) echo "Unknown option: $1"; usage ;;
            esac
        done
        start "$REMOTE" "$SERVER_NAME"
        ;;
    stop)
        [[ $# -lt 1 ]] && usage
        REMOTE="$1"
        shift
        SERVER_NAME=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --server-name) SERVER_NAME="$2"; shift 2 ;;
                *) echo "Unknown option: $1"; usage ;;
            esac
        done
        stop "$REMOTE" "$SERVER_NAME"
        ;;
    status)
        [[ $# -lt 1 ]] && usage
        REMOTE="$1"
        shift
        SERVER_NAME=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --server-name) SERVER_NAME="$2"; shift 2 ;;
                *) echo "Unknown option: $1"; usage ;;
            esac
        done
        status "$REMOTE" "$SERVER_NAME"
        ;;
    logs)
        [[ $# -lt 1 ]] && usage
        REMOTE="$1"
        shift
        SERVER_NAME=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --server-name) SERVER_NAME="$2"; shift 2 ;;
                --follow) FOLLOW=1; shift ;;
                *) echo "Unknown option: $1"; usage ;;
            esac
        done
        logs "$REMOTE" "$SERVER_NAME"
        ;;
    list)
        [[ $# -lt 1 ]] && usage
        REMOTE="$1"
        list_servers "$REMOTE"
        ;;
    config)
        [[ $# -lt 1 ]] && usage
        REMOTE="$1"
        shift
        echo "Reading server-side config from $REMOTE..."
        CONFIG_DIR=$(ssh "$REMOTE" "grep '^CONFIG_DIR=' /home/minecraft-servers/config 2>/dev/null | cut -d= -f2 || echo '/home/minecraft-servers'")
        ssh "$REMOTE" "cat '$CONFIG_DIR/config' 2>/dev/null && echo '' && ls -la '$CONFIG_DIR/servers/'"
        ;;
    validate)
        [[ $# -lt 1 ]] && usage
        REMOTE="$1"
        shift
        SERVER_NAME=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --server-name) SERVER_NAME="$2"; shift 2 ;;
                *) echo "Unknown option: $1"; usage ;;
            esac
        done
        validate_config "$REMOTE" "$SERVER_NAME"
        ;;
    version)
        version
        ;;
    *)
        echo "Unknown command: $COMMAND"
        usage
        ;;
esac
